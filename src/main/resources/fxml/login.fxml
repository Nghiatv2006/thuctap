<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="CENTER" spacing="30.0" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.project.controller.LoginController"
      style="-fx-background-color: linear-gradient(to bottom right, #1e1b4b, #0f172a); -fx-padding: 50px 40px; -fx-font-family: 'Segoe UI', system-ui;">

    <!-- Logo / Title Header -->
    <VBox alignment="CENTER" spacing="8.0">
        <!-- Styled Icon Badge -->
        <HBox alignment="CENTER" style="-fx-background-color: rgba(59, 130, 246, 0.15); -fx-background-radius: 50px; -fx-padding: 15px; -fx-min-width: 60px; -fx-min-height: 60px; -fx-max-width: 60px; -fx-max-height: 60px;">
            <Label text="📦" style="-fx-font-size: 28px;"/>
        </HBox>
        <VBox alignment="CENTER" spacing="2.0" style="-fx-padding: 10px 0 0 0;">
            <Label text="INVENTORY HUB" 
                   style="-fx-font-family: 'Segoe UI Semibold', Arial; -fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #ffffff; -fx-letter-spacing: 2px;"/>
            <Label text="Hệ Thống Quản Lý Kho Nhiều Chi Nhánh" 
                   style="-fx-font-family: 'Segoe UI', Arial; -fx-font-size: 13px; -fx-text-fill: #94a3b8;"/>
        </VBox>
    </VBox>

    <!-- Glassmorphic Login Form Card -->
    <VBox spacing="18.0" prefWidth="360.0" maxWidth="360.0"
          style="-fx-background-color: rgba(30, 41, 59, 0.65); -fx-background-radius: 16px; -fx-border-color: rgba(255, 255, 255, 0.08); -fx-border-width: 1px; -fx-border-radius: 16px; -fx-padding: 30px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.35), 15, 0, 0, 8);">
        
        <Label text="Đăng nhập tài khoản" style="-fx-font-family: 'Segoe UI Semibold'; -fx-text-fill: #ffffff; -fx-font-size: 16px; -fx-font-weight: bold;"/>

        <!-- Username field -->
        <VBox spacing="6.0">
            <Label text="Tên đăng nhập" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <TextField fx:id="usernameField" promptText="Nhập tên đăng nhập..." 
                       style="-fx-background-color: rgba(15, 23, 42, 0.6); -fx-text-fill: #ffffff; -fx-padding: 12px 14px; -fx-background-radius: 8px; -fx-border-color: rgba(255, 255, 255, 0.1); -fx-border-radius: 8px; -fx-font-size: 13px;"/>
        </VBox>
        
        <!-- Password field -->
        <VBox spacing="6.0">
            <Label text="Mật khẩu" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            <PasswordField fx:id="passwordField" promptText="Nhập mật khẩu..." 
                           style="-fx-background-color: rgba(15, 23, 42, 0.6); -fx-text-fill: #ffffff; -fx-padding: 12px 14px; -fx-background-radius: 8px; -fx-border-color: rgba(255, 255, 255, 0.1); -fx-border-radius: 8px; -fx-font-size: 13px;"/>
        </VBox>
        
        <!-- Error Label -->
        <Label fx:id="errorLabel" text="" style="-fx-text-fill: #ef4444; -fx-font-size: 12px; -fx-wrap-text: true;" managed="false" visible="false"/>

        <!-- Login Button inside card for spacing -->
        <Button fx:id="loginButton" text="Đăng Nhập" onAction="#handleLogin" maxWidth="Infinity"
                style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 12px; -fx-background-radius: 8px; -fx-font-weight: bold; -fx-font-size: 14px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(59, 130, 246, 0.25), 8, 0, 0, 4);"/>
    </VBox>

    <!-- Footer Copyright -->
    <Label text="© 2026 Inventory Hub. All rights reserved." style="-fx-text-fill: #475569; -fx-font-size: 11px;"/>

</VBox>
